# THEME SWITCHER

echo "‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó"
echo "‚ēĎ      ūüé® TERMUX THEME SWITCHER ūüé®     ‚ēĎ"
echo "‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ"
echo ""
echo "1. Cyberpunk (Neon pink/green)"
echo "2. Matrix (Green terminal)"
echo "3. Dracula (Purple dark)"
echo "4. Nord (Arctic blue)"
echo "5. Neon Night (Red/teal)"
echo "6. Classic (Black/white)"
echo ""
read -p "Select theme (1-6): " choice

case $choice in
    1)
        cp ~/.termux/cyberpunk.properties ~/.termux/colors.properties
        echo "‚úÖ Cyberpunk theme applied!"
        ;;
    2)
        cp ~/.termux/matrix.properties ~/.termux/colors.properties
        echo "‚úÖ Matrix theme applied!"
        ;;
    3)
        termux-style colors/dracula
        echo "‚úÖ Dracula theme applied!"
        ;;
    4)
        termux-style colors/nord
        echo "‚úÖ Nord theme applied!"
        ;;
    5)
        cp ~/.termux/neon-night.properties ~/.termux/colors.properties
        echo "‚úÖ Neon Night theme applied!"
        ;;
    6)
        termux-style colors/monokai
        echo "‚úÖ Classic theme applied!"
        ;;
    *)
        echo "‚ĚĆ Invalid choice"
        exit 1
        ;;
esac

termux-reload-settings
echo ""
echo "Restart Termux to see changes!"
```

### Animation Launcher
Save as: `animations/launcher.sh`
```bash
#!/bin/bash
# ANIMATION LAUNCHER

echo "‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó"
echo "‚ēĎ      ūüé¨ ANIMATION LAUNCHER ūüé¨        ‚ēĎ"
echo "‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ"
echo ""
echo "1. Matrix Rain"
echo "2. ASCII Fire"
echo "3. Terminal Art"
echo "4. Pipe Dreams (pipes-sh)"
echo "5. CMatrix (Matrix effect)"
echo "6. Cowsay Fortune"
echo ""
read -p "Select animation (1-6): " choice

case $choice in
    1)
        bash ~/bin/matrix-rain
        ;;
    2)
        bash ~/bin/fire-effect
        ;;
    3)
        bash ~/bin/hackerman
        ;;
    4)
        pipes-sh
        ;;
    5)
        cmatrix
        ;;
    6)
        fortune | cowsay
        ;;
    *)
        echo "Invalid choice"
        ;;
esac
```

