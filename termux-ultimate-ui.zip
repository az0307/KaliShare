## ūüé® INSTALL SCRIPT

### `install.sh`
```bash
#!/bin/bash
# ULTIMATE TERMUX UI INSTALLER

set -e

echo -e "\033[1;35m‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó"
echo -e "\033[1;35m‚ēĎ                                                            ‚ēĎ"
echo -e "\033[1;35m‚ēĎ       ūüĒ• TERMUX ULTIMATE UI INSTALLER ūüĒ•                   ‚ēĎ"
echo -e "\033[1;35m‚ēĎ                                                            ‚ēĎ"
echo -e "\033[1;35m‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ\033[0m"
echo ""

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Function
progress() {
    echo -e "${GREEN}[*]${NC} $1"
}

error() {
    echo -e "${RED}[!]${NC} $1"
}

# Update
progress "Updating packages..."
pkg update -y && pkg upgrade -y

# Install base
progress "Installing UI packages..."
pkg install -y \
    termux-styling \
    termux-api \
    zsh \
    starship \
    tmux \
    neofetch \
    bat \
    lsd \
    fzf \
    cmatrix \
    cowsay \
    fortune \
    sl \
    pipes-sh \
    boxes

# Create directories
progress "Creating directories..."
mkdir -p ~/.termux/colors
mkdir -p ~/.termux/fonts
mkdir -p ~/bin

# Download themes
progress "Installing themes..."
curl -s https://raw.githubusercontent.com/termux/termux-styling/master/app/src/main/assets/colors/dracula.properties > ~/.termux/colors.properties

# Create custom themes
cat > ~/.termux/cyberpunk.properties << 'EOF'
background=#0d0d1a
foreground=#00ff9f
cursor=#ff00ff
color0=#1a1a2e
color1=#ff007f
color2=#00ff9f
color3=#ffff00
color4=#00bfff
color5=#bf00ff
color6=#ff00bf
color7=#ffffff
color8=#4a4a6a
color9=#ff4a9f
color10=#4affbf
color11=#ffff4a
color12=#4abfff
color13=#bf4aff
color14=#ff4abf
color15=#ffffa0
EOF

# Setup starship
progress "Setting up starship prompt..."
echo 'eval "$(starship init bash)"' >> ~/.bashrc

cat > ~/.config/starship.toml << 'EOF'
# Starship Configuration
[character]
success_symbol = "[‚ěú](bold green)"
error_symbol = "[‚úó](bold red)"

[username]
show_always = true
style_user = "bold yellow"
style_root = "bold red"

[hostname]
ssh_only = false
style = "bold dimmed white"

[directory]
style = "bold blue"
EOF

# Setup zsh
progress "Setting up Zsh..."
chsh -s zsh

cat > ~/.zshrc << 'EOF'
# Oh My Zsh disabled - Using custom setup
export ZSH="$HOME/.oh-my-zsh"

# Prompt
eval "$(starship init zsh)"

# Aliases
alias ll='lsd -la'
alias la='lsd -A'
alias ls='lsd'
alias cat='bat'
alias grep='rg'
alias find='fd'
alias top='htop'

# History
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_SPACE

# Colors
export TERM=xterm-256color
EOF

# Setup tmux
progress "Setting up tmux..."
cat > ~/.tmux.conf << 'EOF'
# Enable mouse
set -g mouse on

# Status bar
set -g status-bg black
set -g status-fg green
set -g status-left " #[bold]#S "
set -g status-right "#[fg=green]%H:%M"

# Window
set -g window-status-format "#I:#W"
set -g window-status-current-format "[#I:#W]"
set-window-option -g window-status-current-style "fg=black,bg=green"

# Pane
set -g pane-border-style "fg=green"
set -g pane-active-border-style "fg=yellow"
EOF

# Create fun commands
progress "Installing fun animations..."
cat > ~/bin/matrix-rain << 'EOF'
#!/bin/bash
cmatrix -bs
EOF
chmod +x ~/bin/matrix-rain

cat > ~/bin/fire-effect << 'EOF'
#!/bin/bash
pkg install -y caca-utils
cacafire
EOF
chmod +x ~/bin/fire-effect

cat > ~/bin/welcome << 'EOF'
#!/bin/bash
clear
echo -e "\033[1;32m"
neofetch
echo ""
fortune | cowsay
echo -e "\033[0m"
EOF
chmod +x ~/bin/welcome

# Create welcome message
progress "Creating welcome message..."
cat > ~/.bashrc << 'EOF'
# Custom welcome
if [ -f ~/bin/welcome ]; then
    ~/bin/welcome
fi

# Starship
eval "$(starship init bash)"

# Aliases
alias ll='lsd -la'
alias la='lsd -A'
alias ls='lsd'
alias cat='bat'
alias update='pkg update && pkg upgrade -y'
EOF

echo ""
echo -e "${GREEN}‚úÖ Setup Complete!${NC}"
echo ""
echo -e "${CYAN}Usage:${NC}"
echo "  matrix-rain    - Matrix animation"
echo "  fire-effect    - Fire animation"
echo "  welcome        - Show welcome"
echo "  lsd            - Files with icons"
echo "  bat            - Syntax highlight"
echo ""
echo -e "${YELLOW}Restart Termux to see changes!${NC}"
```

